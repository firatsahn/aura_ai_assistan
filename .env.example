# Copy to .env and fill in. .env is gitignored.

# Which provider runs the vision step (docs 03 and 05).
# Leave blank to auto-detect from whichever key is set below.
#   anthropic -> Claude (default)
#   gemini    -> Google Gemini
VISION_PROVIDER=

# --- Claude (default provider) ---
# The Anthropic SDK reads this variable name by default.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
# VISION_MODEL=claude-opus-4-8

# --- Gemini (alternative provider; set VISION_PROVIDER=gemini) ---
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-pro

# --- Embeddings (Step 2): OpenAI ---
# Used for both document indexing and query-time embedding.
OPENAI_API_KEY=
# Optional model override (default: text-embedding-3-small, 1536 dims)
# EMBEDDING_MODEL=text-embedding-3-small

# --- Vector store (Step 2): Qdrant ---
# Local dev: http://localhost:6333. In Docker Compose: http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aura_corpus

# --- Generation (Step 3a): OpenAI ---
# Reuses OPENAI_API_KEY above. Default model: gpt-4o-mini.
# GENERATION_MODEL=gpt-4o-mini
# Abstention: if the best retrieval hit scores below this, the system answers
# "couldn't find it" instead of calling the model. Default 0.38 calibrated on
# this corpus (relevant ~0.40-0.64, out-of-corpus ~0.29-0.34).
# ABSTENTION_THRESHOLD=0.38
